# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-...

# Extraction model (Phase 3). Pin a specific snapshot for reproducible eval numbers.
POLICYFORGE_EXTRACTION_MODEL=claude-sonnet-4-6

# Chroma (Phase 2 treatment arm). Embeddings come from a LOCAL Ollama server
# (loopback only, no external egress). Pin the model for reproducible retrieval.
POLICYFORGE_CHROMA_COLLECTION=ncci_policy_manual
POLICYFORGE_OLLAMA_BASE_URL=http://localhost:11434
POLICYFORGE_EMBEDDING_MODEL=nomic-embed-text

# Local paths (not committed)
POLICYFORGE_DATA_DIR=./data
